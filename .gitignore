# ============================================================
#  Unreal Engine 5.3 - .gitignore
# ============================================================

# 빌드 산출물 / 중간 파일
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
.vs/
.vscode/
*.VC.db
*.opensdf
*.opendb
*.sdf
*.sln
*.suo
*.xcodeproj
*.xcworkspace

# 사용자 로컬 설정
Saved/Config/
Config/*Local*

# 플러그인 빌드 산출물 (플러그인 소스는 추적, 산출물은 제외)
Plugins/**/Binaries/
Plugins/**/Intermediate/

# 크래시/로그
*.log
*.tmp
*.stackdump

# OS
Thumbs.db
Desktop.ini
.DS_Store

# ============================================================
#  원본 오디오 소스 (Content 내)
#  WAV/MP3 를 임포트하면 .uasset(SoundWave)에 데이터가 내장되므로
#  원본 파일은 추적하지 않는다. (리포 용량 절감)
#  → 재편집용 원본이 필요하면 리포 밖 폴더에 별도 보관할 것.
# ============================================================
LostArk/Content/**/*.mp3
LostArk/Content/**/*.wav
LostArk/Content/**/*.ogg
LostArk/Content/**/*.flac
LostArk/Content/**/*.aif
LostArk/Content/**/*.aiff

# ============================================================
#  주의: .uproject / Source / Content / Config(공용) 은 추적한다
# ============================================================
